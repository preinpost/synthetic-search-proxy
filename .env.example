# Synthetic web search API key (required)
SYNTHETIC_API_KEY=sk-...

# Bearer token Open WebUI must present. Set the same value as
# "External Web Search API Key" in Open WebUI. Leave empty to disable auth.
PROXY_KEY=change-me

# Optional overrides
# SYNTHETIC_URL=https://api.synthetic.new/v2/search
# REQUEST_TIMEOUT=20
# LOG_LEVEL=INFO
# PORT=8000
# Max chars per snippet. Synthetic returns full page text; forwarding it whole
# bloats the response (~1MB) and overflows the model request in agentic mode.
# 0 = no limit.
# SNIPPET_MAX_CHARS=2000
